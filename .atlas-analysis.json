  "keyFeatures": [
    "Modern 64-bit kernel with pre-emptive multi-threading",
    "Custom browser with JavaScript, WebAssembly, and modern web standards",
    "Complete desktop environment with window server and GUI applications",
    "POSIX compatibility with custom LibC implementation",
    "Security features including pledge, unveil, KASLR, and W^X memory",
    "Native development tools including IDE, debugger, and profiler",
    "Built-in applications for productivity, media, and gaming",
    "Network stack with IPv4, TCP/UDP, HTTP, and more",
    "Over 300 ported open-source applications"
  ],
  "publicApiSurface": [
    "AK - Custom C++ standard library",
    "LibC - POSIX C library implementation",
    "LibCore - Core system utilities and event loop",
    "LibGUI - GUI toolkit and widgets",
    "LibGfx - Graphics primitives and rendering",
    "LibGL - OpenGL implementation",
    "LibWeb - Web engine (HTML, CSS, JavaScript)",
    "LibJS - JavaScript engine",
    "LibAudio - Audio playback and encoding",
    "LibProtocol - Network protocol implementations",
    "LibIPC - Inter-process communication",
    "Kernel syscalls - System call interface",
    "WindowServer - Window management IPC",
    "AudioServer - Audio service IPC"
